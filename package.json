{
  "name": "n8n-nodes-autotask",
  "version": "2.9.0",
  "description": "n8n node for Autotask PSA integration",
  "keywords": [
    "n8n-community-node-package",
    "autotask",
    "psa",
    "datto",
    "n8n"
  ],
  "license": "MIT",
  "homepage": "https://github.com/msoukhomlinov/n8n-nodes-autotask",
  "author": {
    "name": "Max Soukhomlinov",
    "email": "maxs@intellectit.com.au"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msoukhomlinov/n8n-nodes-autotask.git"
  },
  "engines": {
    "node": ">=18.10",
    "pnpm": ">=9.1"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/nodes/Autotask/Autotask.node.js",
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "n8n-node lint",
    "lintfix": "n8n-node lint --fix",
    "lint:fix": "n8n-node lint --fix",
    "typecheck": "tsc --noEmit",
    "release": "n8n-node release",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/AutotaskApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Autotask/Autotask.node.js",
      "dist/nodes/Autotask/AutotaskTrigger.node.js",
      "dist/nodes/Autotask/AutotaskAiTools.node.js"
    ]
  },
  "devDependencies": {
    "@langchain/classic": "^1.0.29",
    "@langchain/core": "^1.1.39",
    "@n8n/node-cli": ">=0.17.0",
    "@types/node": "^22.15.0",
    "@types/pluralize": "^0.0.33",
    "eslint": "9.32.0",
    "n8n-workflow": "^2.13.1",
    "prettier": "^3.3.2",
    "typescript": "^5.6.3",
    "zod": "^3.23.0"
  },
  "dependencies": {
    "change-case": "^4.1.2",
    "keyv": "^5.6.0",
    "keyv-file": "^5.3.3",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.47",
    "pluralize": "^8.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
